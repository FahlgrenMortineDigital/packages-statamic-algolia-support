{
    "name": "fahlgrendigital/packages-statamic-algolia-support",
    "description": "Support for the Algolia driver in Statamic applications.",
    "license": "MIT",
    "keywords": [
        "statamic",
        "cms",
        "flat file",
        "laravel"
    ],
    "autoload": {
        "psr-4": {
            "Fahlgrendigital\\PackagesStatamicAlgoliaSupport\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Andrew Clinton",
            "email": "andrew.clinton@fahlgren.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0",
        "statamic/cms": "^5.0|^6.0",
        "league/csv": "^9.21.0",
        "algolia/algoliasearch-client-php": "^4.32"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.7.4",
        "pestphp/pest-plugin-laravel": "^3.1"
    },
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "statamic": {
            "name": "Algolia Support",
            "description": "Support for the Algolia driver in Statamic applications."
        },
        "laravel": {
            "providers": [
                "Fahlgrendigital\\PackagesStatamicAlgoliaSupport\\StatamicAlgoliaSupportProvider"
            ]
        }
    }
}
